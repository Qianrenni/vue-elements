{
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "npx prettier --write \"packages/**/*.{js,ts,vue,css,md}\"",
    "build:components": "pnpm run --filter qyani-components build",
    "docs:dev": "pnpm run --filter @qyani-components/docs dev",
    "docs:update": "pnpm run --filter @qyani-components/docs update",
    "docs:build": "pnpm run --filter qyani-components build && pnpm run --filter @qyani-components/docs build",
    "prepare": "husky install "
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@qyani/eslint-config": "workspace:*",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.{js,ts,vue,css,md}": [
        "prettier --write",
        "eslint --cache --fix"
    ]
  }
}
